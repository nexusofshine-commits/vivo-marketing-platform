page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  max-width: 480px;
  margin: 0 auto;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

page {
  background-color: #f5f6fa;
}

.primary {
  color: #0066FF;
}

.success {
  color: #00C853;
}

.warning {
  color: #FF9500;
}

.danger {
  color: #FF3B30;
}

.text-primary {
  color: #191919;
}

.text-secondary {
  color: #666666;
}

.text-tertiary {
  color: #999999;
}

.bg-primary {
  background-color: #FFFFFF;
}

.bg-secondary {
  background-color: #f5f6fa;
}

.border {
  border: 2rpx solid #e8ebf0;
}
