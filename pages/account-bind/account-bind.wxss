.container {
  min-height: 100vh;
  background: #f5f6fa;
}

.navbar {
  background: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f1f5;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
}

.bind-content {
  padding: 32rpx 24rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.role-options {
  display: flex;
  gap: 16rpx;
}

.role-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f0f1f5;
  transition: all 0.3s;
  position: relative;
}

.role-option.selected {
  border-color: #0066FF;
  background: rgba(0,102,255,0.05);
}

.role-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.role-name {
  font-size: 24rpx;
  color: #666;
}

.role-option.selected .role-name {
  color: #0066FF;
  font-weight: 500;
}

.role-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #0066FF;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
}

.role-option.selected .role-check {
  opacity: 1;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #191919;
  box-sizing: border-box;
}

.bind-btn {
  background: #0066FF;
  color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.bind-btn:active {
  opacity: 0.8;
}

.tips-text {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}