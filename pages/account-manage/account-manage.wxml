<view class="container">
  <view class="navbar">
    <text class="navbar-title">{{isMultiAccount ? '账户管理' : '推广管理'}}</text>
  </view>

  <view wx:if="{{isMultiAccount}}" class="account-view">
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-value">{{accountCount}}</text>
        <text class="stat-label">总账户</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{runningCount}}</text>
        <text class="stat-label">投放中</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{todayCost}}</text>
        <text class="stat-label">今日总花费</text>
      </view>
    </view>

    <view class="account-group">
      <text class="group-label">投放账号</text>
      <view wx:for="{{adAccounts}}" wx:key="name" class="account-card" bindtap="goToPromotion" data-name="{{item.name}}">
        <view class="card-left">
          <view class="card-icon" style="background:{{item.iconBg}};color:{{item.iconColor}};">🎯</view>
          <view class="card-info">
            <text class="card-name">{{item.name}}</text>
            <text class="card-meta">{{item.meta}}</text>
          </view>
        </view>
        <view class="card-right">
          <text class="card-status {{item.statusClass}}">{{item.statusText}}</text>
          <text class="card-arrow">›</text>
        </view>
      </view>
    </view>

    <view wx:if="{{multiAccounts.length > 0}}" class="account-group">
      <text class="group-label">多账户管理</text>
      <view wx:for="{{multiAccounts}}" wx:key="name" class="account-card" bindtap="goToPromotion" data-name="{{item.name}}">
        <view class="card-left">
          <view class="card-icon" style="background:#E8F5E9;color:#2E7D32;">📊</view>
          <view class="card-info">
            <text class="card-name">{{item.name}}</text>
            <text class="card-meta">{{item.meta}}</text>
          </view>
        </view>
        <view class="card-right">
          <text class="card-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="promotion-view">
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-value">{{planCount}}</text>
        <text class="stat-label">推广计划</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{runningPlans}}</text>
        <text class="stat-label">投放中</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{todayCost}}</text>
        <text class="stat-label">今日花费</text>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">推广计划列表</text>
      <view wx:for="{{planList}}" wx:key="name" class="list-item" bindtap="goToPlanDetail" data-name="{{item.name}}">
        <view class="item-left">
          <view class="item-icon" style="background:{{item.iconBg}};">📋</view>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-meta">{{item.type}} · {{item.statusText}}</text>
          </view>
        </view>
        <view class="item-right">
          <text class="item-value">{{item.cost}}</text>
          <text class="item-unit">花费(元)</text>
        </view>
      </view>
    </view>
  </view>
</view>