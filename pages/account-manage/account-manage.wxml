<view class="container">
  <view class="navbar">
    <text class="navbar-title">账户管理</text>
  </view>

  <view class="account-overview">
    <view class="overview-item">
      <text class="overview-value">5</text>
      <text class="overview-label">总账户</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">3</text>
      <text class="overview-label">投放中</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">¥36,200</text>
      <text class="overview-label">今日总花费</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">567w</text>
      <text class="overview-label">总曝光</text>
    </view>
  </view>

  <view class="account-group">
    <text class="group-label">投放账号</text>
    <view class="account-card" bindtap="goToPromotion" data-name="唯品会拉新A">
      <view class="card-left">
        <view class="card-icon" style="background:#E8F0FF;color:#0F62FE;">🎯</view>
        <view class="card-info">
          <text class="card-name">唯品会拉新A</text>
          <text class="card-meta">今日 ¥15,234 · OCPC</text>
        </view>
      </view>
      <view class="card-right">
        <text class="card-status running">投放中</text>
        <text class="card-arrow">›</text>
      </view>
    </view>
    <view class="account-card" bindtap="goToPromotion" data-name="唯品会拉新B">
      <view class="card-left">
        <view class="card-icon" style="background:#E8F0FF;color:#0F62FE;">🎯</view>
        <view class="card-info">
          <text class="card-name">唯品会拉新B</text>
          <text class="card-meta">今日 ¥8,567 · OCPC</text>
        </view>
      </view>
      <view class="card-right">
        <text class="card-status running">投放中</text>
        <text class="card-arrow">›</text>
      </view>
    </view>
    <view class="account-card" bindtap="goToPromotion" data-name="唯品会拉活A">
      <view class="card-left">
        <view class="card-icon" style="background:#FFF3E0;color:#FF832B;">🎯</view>
        <view class="card-info">
          <text class="card-name">唯品会拉活A</text>
          <text class="card-meta">今日 ¥12,456 · OCPC</text>
        </view>
      </view>
      <view class="card-right">
        <text class="card-status paused">已暂停</text>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="account-group">
    <text class="group-label">多账户管理</text>
    <view class="account-card" bindtap="goToPromotion" data-name="唯品会OCPC账户集合">
      <view class="card-left">
        <view class="card-icon" style="background:#E8F5E9;color:#2E7D32;">📊</view>
        <view class="card-info">
          <text class="card-name">唯品会OCPC账户集合</text>
          <text class="card-meta">3个子账户 · 今日 ¥36,257</text>
        </view>
      </view>
      <view class="card-right">
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="account-group">
    <text class="group-label">经营主体</text>
    <view class="account-card" bindtap="goToPromotion" data-name="唯品会主体管理员">
      <view class="card-left">
        <view class="card-icon" style="background:#F3E5F5;color:#7B1FA2;">🏢</view>
        <view class="card-info">
          <text class="card-name">唯品会主体管理员</text>
          <text class="card-meta">2个多账户 · 5个投放账号</text>
        </view>
      </view>
      <view class="card-right">
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>
</view>