.container {
    min-height: 100vh;
    background: #f5f6fa;
    padding-bottom: 120rpx;
}

.navbar {
    background: #fff;
    height: 88rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1rpx solid #f0f1f5;
}

.navbar-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #191919;
}

.stat-row {
    background: #fff;
    margin: 16rpx 24rpx;
    border-radius: 20rpx;
    padding: 24rpx;
    display: flex;
    justify-content: space-between;
}

.stat-item {
    flex: 1;
    text-align: center;
}

.stat-value {
    font-size: 30rpx;
    font-weight: 700;
    color: #191919;
    display: block;
    margin-bottom: 6rpx;
}

.stat-label {
    font-size: 20rpx;
    color: #999;
}

.filter-bar {
    display: flex;
    gap: 16rpx;
    padding: 0 24rpx;
    margin-bottom: 16rpx;
}

.filter-btn {
    padding: 12rpx 28rpx;
    border-radius: 10rpx;
    font-size: 24rpx;
    color: #666;
    background: #fff;
    border: 1rpx solid #e8ebf0;
}

.filter-btn.active {
    background: #0066FF;
    color: #fff;
    border-color: #0066FF;
}

.version-toggle {
    display: flex;
    margin: 16rpx 24rpx;
    background: #fff;
    border-radius: 12rpx;
    border: 1rpx solid #e8ebf0;
    overflow: hidden;
}

.toggle-btn {
    flex: 1;
    text-align: center;
    padding: 16rpx 0;
    font-size: 26rpx;
    color: #666;
    font-weight: 500;
}

.toggle-btn.active {
    background: #0066FF;
    color: #fff;
}

.promo-tabs {
    display: flex;
    padding: 0 24rpx;
    gap: 0;
    background: #fff;
    border-bottom: 1rpx solid #f0f1f5;
}

.promo-tab {
    flex: 1;
    text-align: center;
    padding: 20rpx 0;
    font-size: 26rpx;
    color: #666;
    position: relative;
    font-weight: 500;
}

.promo-tab.active {
    color: #0066FF;
}

.promo-tab.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40rpx;
    height: 4rpx;
    background: #0066FF;
    border-radius: 4rpx;
}

.section-card {
    background: #fff;
    margin: 16rpx 24rpx;
    border-radius: 20rpx;
    padding: 24rpx;
}

.section-title {
    font-size: 28rpx;
    font-weight: 600;
    color: #191919;
    margin-bottom: 20rpx;
    display: block;
}

.list-item {
    display: flex;
    align-items: center;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f5f6fa;
}

.list-item:last-child {
    border-bottom: none;
}

.item-left {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
}

.item-icon {
    width: 64rpx;
    height: 64rpx;
    border-radius: 14rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    margin-right: 16rpx;
    flex-shrink: 0;
}

.item-info {
    flex: 1;
    min-width: 0;
}

.item-name {
    font-size: 26rpx;
    font-weight: 600;
    color: #191919;
    display: block;
    margin-bottom: 4rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.item-meta {
    font-size: 22rpx;
    color: #999;
}

.item-right {
    display: flex;
    align-items: center;
    gap: 12rpx;
    flex-shrink: 0;
    margin-left: 16rpx;
}

.item-status {
    font-size: 20rpx;
    font-weight: 500;
    padding: 6rpx 14rpx;
    border-radius: 8rpx;
}

.item-status.running {
    color: #00C853;
    background: rgba(0,200,83,0.08);
}

.item-status.paused {
    color: #FF9500;
    background: rgba(255,149,0,0.08);
}

.item-value {
    font-size: 28rpx;
    font-weight: 700;
    color: #0066FF;
    display: block;
    text-align: right;
}

.item-unit {
    font-size: 20rpx;
    color: #999;
    display: block;
    text-align: right;
}

.item-arrow {
    color: #ccc;
    font-size: 28rpx;
}

.edit-btn {
    padding: 10rpx 20rpx;
    background: #0066FF;
    color: #fff;
    border-radius: 8rpx;
    font-size: 22rpx;
    font-weight: 500;
    flex-shrink: 0;
}

.plan-card-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.plan-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx;
    border: 1rpx solid #f0f1f5;
    transition: all 0.2s;
}

.plan-card:active {
    background: #f8f9fa;
}

.plan-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16rpx;
}

.plan-name-section {
    display: flex;
    align-items: center;
    gap: 16rpx;
    flex: 1;
    min-width: 0;
}

.plan-icon {
    width: 64rpx;
    height: 64rpx;
    border-radius: 12rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    flex-shrink: 0;
}

.plan-name-wrapper {
    flex: 1;
    min-width: 0;
}

.plan-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #191919;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 6rpx;
}

.plan-meta {
    font-size: 22rpx;
    color: #999;
}

.plan-header-right {
    display: flex;
    align-items: center;
    gap: 12rpx;
    flex-shrink: 0;
}

.plan-status {
    font-size: 20rpx;
    font-weight: 500;
    padding: 6rpx 14rpx;
    border-radius: 6rpx;
}

.plan-status.running {
    color: #00C853;
    background: rgba(0,200,83,0.08);
}

.plan-status.paused {
    color: #FF9500;
    background: rgba(255,149,0,0.08);
}

.plan-arrow {
    color: #ccc;
    font-size: 28rpx;
}

.plan-metrics-section {
    display: flex;
    justify-content: space-between;
    margin-top: 16rpx;
    padding-top: 16rpx;
    border-top: 1rpx solid #f5f6fa;
    gap: 32rpx;
}

.metrics-left,
.metrics-right {
    flex: 1;
}

.metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10rpx 0;
}

.metric-row:first-child {
    padding-top: 0;
}

.metric-row:last-child {
    padding-bottom: 0;
}

.metric-label {
    font-size: 22rpx;
    color: #999;
}

.metric-value {
    font-size: 26rpx;
    font-weight: 600;
    color: #191919;
}

.metric-value.cost {
    color: #0066FF;
}

.metric-value.target {
    color: #00C853;
}

.metric-value.target-cpc {
    color: #FF9500;
}

.modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-container {
    background: #fff;
    width: 84%;
    border-radius: 20rpx;
    overflow: hidden;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32rpx;
    border-bottom: 1rpx solid #f0f1f5;
}

.modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #191919;
}

.modal-close {
    font-size: 40rpx;
    color: #999;
    width: 48rpx;
    height: 48rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-body {
    padding: 32rpx;
}

.modal-label {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 16rpx;
    display: block;
}

.input-row {
    display: flex;
    align-items: center;
    background: #f5f6fa;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
}

.edit-input {
    flex: 1;
    font-size: 28rpx;
    color: #191919;
}

.input-unit {
    font-size: 26rpx;
    color: #666;
    margin-left: 12rpx;
    flex-shrink: 0;
}

.modal-footer {
    display: flex;
    border-top: 1rpx solid #f0f1f5;
    padding: 24rpx 32rpx;
    gap: 20rpx;
}

.modal-btn {
    flex: 1;
    height: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16rpx;
    font-size: 28rpx;
    font-weight: 500;
}

.modal-btn.cancel {
    background: #f5f6fa;
    color: #666;
}

.modal-btn.confirm {
    background: #0066FF;
    color: #fff;
}

.promo-item {
    align-items: flex-start;
}

.promo-right {
    flex-shrink: 0;
}

.promo-stats {
    text-align: right;
}

.promo-stats .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    margin: 0;
    padding: 0;
    border-radius: 0;
}

.promo-stats .stat-label {
    font-size: 20rpx;
    color: #999;
    flex-shrink: 0;
    margin-right: 12rpx;
}

.stat-cost {
    font-size: 28rpx;
    font-weight: 700;
    color: #0066FF;
}

.stat-budget {
    font-size: 24rpx;
    color: #191919;
    font-weight: 500;
}

.budget-row {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.edit-icon {
    font-size: 24rpx;
    padding: 4rpx;
}

.edit-icon:active {
    opacity: 0.7;
}