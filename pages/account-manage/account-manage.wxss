.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 100rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f1f5;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
}

.stat-row {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #191919;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

.account-group {
  margin: 0 24rpx 8rpx;
}

.group-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  padding: 20rpx 8rpx 12rpx;
  font-weight: 500;
}

.account-card {
  background: #fff;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #f0f1f5;
}

.card-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  font-size: 22rpx;
  color: #999;
}

.card-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.card-status {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.card-status.running {
  color: #00C853;
  background: rgba(0,200,83,0.08);
}

.card-status.paused {
  color: #FF9500;
  background: rgba(255,149,0,0.08);
}

.card-arrow {
  color: #ccc;
  font-size: 28rpx;
}

.section-card {
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}

.list-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  font-size: 22rpx;
  color: #999;
}

.item-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0066FF;
  display: block;
  margin-bottom: 4rpx;
}

.item-unit {
  font-size: 20rpx;
  color: #999;
}