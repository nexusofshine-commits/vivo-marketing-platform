<view class="container">
  <view class="navbar">
    <text class="navbar-title">商业化角色切换</text>
  </view>

  <view class="role-tabs">
    <view class="role-tab {{currentTab === 'business' ? 'active' : ''}}" bindtap="switchTab" data-tab="business">
      <text class="tab-text">经营主体</text>
      <text class="tab-count">{{businessCount}}</text>
    </view>
    <view class="role-tab {{currentTab === 'unit' ? 'active' : ''}}" bindtap="switchTab" data-tab="unit">
      <text class="tab-text">业务单元</text>
      <text class="tab-count">{{unitCount}}</text>
    </view>
    <view class="role-tab {{currentTab === 'account' ? 'active' : ''}}" bindtap="switchTab" data-tab="account">
      <text class="tab-text">投放账号</text>
      <text class="tab-count">{{accountCount}}</text>
    </view>
  </view>

  <view class="tab-content">
    <view wx:if="{{currentTab === 'business' && businessList.length > 0}}" class="account-list">
      <view wx:for="{{businessList}}" wx:key="name" class="account-card" bindtap="selectAccount" data-name="{{item.name}}" data-type="经营主体">
        <view class="card-icon" style="background:#F3E5F5;color:#7B1FA2;">🏢</view>
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-meta">{{item.accountCount}}个业务单元 · {{item.totalAccounts}}个投放账号</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{currentTab === 'business' && businessList.length === 0}}" class="empty-state">
      <view class="empty-icon">📭</view>
      <text class="empty-text">暂无绑定的经营主体</text>
      <view class="empty-btn" bindtap="goToBind">去绑定</view>
    </view>

    <view wx:if="{{currentTab === 'unit' && unitList.length > 0}}" class="account-list">
      <view wx:for="{{unitList}}" wx:key="name" class="account-card" bindtap="selectAccount" data-name="{{item.name}}" data-type="业务单元">
        <view class="card-icon" style="background:#E8F5E9;color:#2E7D32;">📊</view>
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-meta">{{item.accountCount}}个投放账号 · 今日 {{item.cost}}</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{currentTab === 'unit' && unitList.length === 0}}" class="empty-state">
      <view class="empty-icon">📭</view>
      <text class="empty-text">暂无绑定的业务单元</text>
      <view class="empty-btn" bindtap="goToBind">去绑定</view>
    </view>

    <view wx:if="{{currentTab === 'account' && accountList.length > 0}}" class="account-list">
      <view wx:for="{{accountList}}" wx:key="name" class="account-card" bindtap="selectAccount" data-name="{{item.name}}" data-type="投放账号">
        <view class="card-icon" style="background:#E8F0FF;color:#0F62FE;">🎯</view>
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-meta">今日 {{item.cost}} · {{item.type}}</text>
        </view>
        <text class="card-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>
    </view>

    <view wx:if="{{currentTab === 'account' && accountList.length === 0}}" class="empty-state">
      <view class="empty-icon">📭</view>
      <text class="empty-text">暂无绑定的投放账号</text>
      <view class="empty-btn" bindtap="goToBind">去绑定</view>
    </view>
  </view>
</view>