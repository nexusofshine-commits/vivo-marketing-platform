<view class="container">
  <view class="navbar">
    <text class="navbar-title">商业化角色切换</text>
  </view>

  <view class="account-group">
    <text class="group-label">经营主体</text>
    <view class="account-card" bindtap="selectAccount" data-name="唯品会主体" data-type="经营主体">
      <view class="card-icon" style="background:#F3E5F5;color:#7B1FA2;">🏢</view>
      <view class="card-info">
        <text class="card-name">唯品会主体</text>
        <text class="card-meta">2个业务单元 · 5个投放账号</text>
      </view>
      <text class="card-arrow">›</text>
    </view>
  </view>

  <view class="account-group">
    <text class="group-label">业务单元</text>
    <view class="account-card" bindtap="selectAccount" data-name="拉新业务线" data-type="业务单元">
      <view class="card-icon" style="background:#E8F5E9;color:#2E7D32;">📊</view>
      <view class="card-info">
        <text class="card-name">拉新业务线</text>
        <text class="card-meta">3个投放账号 · 今日 ¥23,801</text>
      </view>
      <text class="card-arrow">›</text>
    </view>
    <view class="account-card" bindtap="selectAccount" data-name="拉活业务线" data-type="业务单元">
      <view class="card-icon" style="background:#E8F5E9;color:#2E7D32;">📊</view>
      <view class="card-info">
        <text class="card-name">拉活业务线</text>
        <text class="card-meta">2个投放账号 · 今日 ¥12,456</text>
      </view>
      <text class="card-arrow">›</text>
    </view>
  </view>

  <view class="account-group">
    <text class="group-label">投放账号</text>
    <view class="account-card" bindtap="selectAccount" data-name="唯品会拉新A" data-type="投放账号">
      <view class="card-icon" style="background:#E8F0FF;color:#0F62FE;">🎯</view>
      <view class="card-info">
        <text class="card-name">唯品会拉新A</text>
        <text class="card-meta">今日 ¥15,234 · OCPC</text>
      </view>
      <text class="card-status running">投放中</text>
    </view>
    <view class="account-card" bindtap="selectAccount" data-name="唯品会拉新B" data-type="投放账号">
      <view class="card-icon" style="background:#E8F0FF;color:#0F62FE;">🎯</view>
      <view class="card-info">
        <text class="card-name">唯品会拉新B</text>
        <text class="card-meta">今日 ¥8,567 · OCPC</text>
      </view>
      <text class="card-status running">投放中</text>
    </view>
    <view class="account-card" bindtap="selectAccount" data-name="唯品会拉活A" data-type="投放账号">
      <view class="card-icon" style="background:#FFF3E0;color:#FF832B;">🎯</view>
      <view class="card-info">
        <text class="card-name">唯品会拉活A</text>
        <text class="card-meta">今日 ¥12,456 · OCPC</text>
      </view>
      <text class="card-status paused">已暂停</text>
    </view>
  </view>
</view>