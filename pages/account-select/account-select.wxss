.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.header {
  background-color: #FFFFFF;
  padding: 40rpx 24rpx 32rpx;
  border-bottom: 1rpx solid #e8ebf0;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #191919;
}

.account-group {
  margin-bottom: 12rpx;
}

.group-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  padding: 28rpx 24rpx 12rpx;
  font-weight: 500;
}

.account-card {
  background-color: #FFFFFF;
  margin: 0 24rpx 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  border: 1rpx solid #e8ebf0;
}

.account-icon {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(0,102,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
}

.account-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.account-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 6rpx;
}

.account-email {
  font-size: 24rpx;
  color: #666666;
}

.account-status {
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 16rpx;
  margin-left: 16rpx;
  border: 1rpx solid;
  border-radius: 10rpx;
}

.status-available {
  color: #0066FF;
  border-color: #0066FF;
  background: rgba(0,102,255,0.05);
}

.status-frozen {
  color: #999999;
  border-color: #e8ebf0;
  background: #f5f6fa;
}
