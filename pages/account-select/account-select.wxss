.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.navbar {
  background: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f1f5;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
}

.account-group {
  margin: 0 24rpx 8rpx;
}

.group-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  padding: 20rpx 8rpx 12rpx;
  font-weight: 500;
}

.account-card {
  background: #fff;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #f0f1f5;
}

.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  display: block;
  margin-bottom: 6rpx;
}

.card-meta {
  font-size: 22rpx;
  color: #999;
}

.card-arrow {
  color: #ccc;
  font-size: 28rpx;
  margin-left: 12rpx;
}

.card-status {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.card-status.running {
  color: #00C853;
  background: rgba(0,200,83,0.08);
}

.card-status.paused {
  color: #FF9500;
  background: rgba(255,149,0,0.08);
}