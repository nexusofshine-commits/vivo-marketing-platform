<view class="container">
  <view class="navbar">
    <text class="navbar-title">智能诊断</text>
  </view>

  <view class="dim-tabs">
    <text class="dim-tab {{currentDim === 'consume' ? 'active' : ''}}" bindtap="switchDim" data-dim="consume">消耗</text>
    <text class="dim-tab {{currentDim === 'convert' ? 'active' : ''}}" bindtap="switchDim" data-dim="convert">转化</text>
    <text class="dim-tab {{currentDim === 'creative' ? 'active' : ''}}" bindtap="switchDim" data-dim="creative">创意</text>
    <text class="dim-tab {{currentDim === 'account' ? 'active' : ''}}" bindtap="switchDim" data-dim="account">账户</text>
  </view>

  <view class="card-list">
    <view wx:for="{{currentCards}}" wx:key="id" class="diag-card">
      <view class="card-header" bindtap="toggleCard" data-id="{{item.id}}">
        <view class="card-level {{item.level}}">{{item.levelText}}</view>
        <view class="card-title-area">
          <text class="card-title">{{item.title}}</text>
          <text class="card-target">{{item.target}}</text>
        </view>
        <view class="card-arrow {{item.expanded ? 'open' : ''}}">▼</view>
      </view>
      <view class="card-body {{item.expanded ? 'open' : ''}}">
        <view class="body-section">
          <text class="body-label">数据详情</text>
          <text class="body-text">{{item.detail}}</text>
        </view>
        <view class="body-section">
          <text class="body-label">建议操作</text>
          <text class="body-text">{{item.suggestion}}</text>
        </view>
        <view wx:if="{{item.action}}" class="card-action">
          <view class="action-btn" bindtap="handleAction" data-action="{{item.action.key}}">{{item.action.name}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="tab-spacer"></view>
</view>