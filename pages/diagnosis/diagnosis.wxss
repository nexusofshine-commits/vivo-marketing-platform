.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.navbar {
  background-color: #FFFFFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f1f5;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
}

.dim-tabs {
  background: #fff;
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #f0f1f5;
}

.dim-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e8ebf0;
  border-radius: 12rpx;
  font-weight: 500;
}

.dim-tab.active {
  background: #0066FF;
  color: #fff;
  border-color: #0066FF;
}

.card-list {
  padding: 16rpx 24rpx;
}

.diag-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #f0f1f5;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.card-level {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.card-level.error {
  background: #FFEBEE;
  color: #FF3B30;
}

.card-level.warn {
  background: #FFF3E0;
  color: #FF9500;
}

.card-level.info {
  background: #E3F2FD;
  color: #0066FF;
}

.card-title-area {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-time {
  font-size: 20rpx;
  color: #bbb;
}

.card-arrow {
  font-size: 20rpx;
  color: #ccc;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.card-arrow.open {
  transform: rotate(180deg);
}

.card-body {
  max-height: 0;
  overflow: hidden;
}

.card-body.open {
  max-height: 800rpx;
}

.body-section {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f6fa;
}

.body-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.body-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.card-actions {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx 24rpx;
  flex-wrap: wrap;
  border-top: 1rpx solid #f5f6fa;
}

.action-tag {
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-tag.primary {
  background: #0066FF;
  color: #fff;
}

.action-tag.outline {
  background: #fff;
  color: #0066FF;
  border: 1rpx solid #0066FF;
}

.tab-spacer {
  height: 100rpx;
}