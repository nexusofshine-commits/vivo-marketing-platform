.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  padding-bottom: 0;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 24rpx;
}

.diagnosis-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
}

.diagnosis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.diagnosis-item {
  border: 1rpx solid #e8ebf0;
  border-radius: 16rpx;
  overflow: hidden;
}

.diagnosis-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafbfc;
}

.diagnosis-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.diagnosis-icon.warning {
  background: #FFF3E0;
}

.diagnosis-icon.info {
  background: #E3F2FD;
}

.diagnosis-icon.error {
  background: #FFEBEE;
}

.diagnosis-info {
  flex: 1;
}

.diagnosis-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 6rpx;
}

.diagnosis-time {
  font-size: 22rpx;
  color: #999999;
}

.diagnosis-arrow {
  font-size: 22rpx;
  color: #999999;
  transition: transform 0.3s;
}

.diagnosis-arrow.open {
  transform: rotate(180deg);
}

.diagnosis-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s;
}

.diagnosis-detail.open {
  max-height: 1500rpx;
}

.detail-section {
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f6fa;
}

.detail-section:last-child {
  border-bottom: none;
  padding-bottom: 20rpx;
}

.detail-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
}

.detail-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fafbfc;
  border-top: 1rpx solid #f0f1f5;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
  background: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: #0066FF;
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #f5f6fa;
  color: #333333;
}

.action-btn.outline {
  background: transparent;
  color: #0066FF;
  border: 1rpx solid #0066FF;
}

.action-btn.success {
  background: #00C853;
  color: #FFFFFF;
}

.action-btn.danger {
  background: #FF3B30;
  color: #FFFFFF;
}

.tab-spacer {
  height: 100rpx;
}
