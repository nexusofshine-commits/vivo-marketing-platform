<view class="container">
  <view class="header">
    <view class="account-row">
      <view class="account-type-tag">{{accountTypeTag}}</view>
      <view class="account-name">{{accountName}}</view>
      <view class="switch-btn" bindtap="goToAccountSelect">
        <text class="switch-icon">⇄</text>
      </view>
      <view class="header-right" bindtap="goToProfile">
        <view class="avatar">👤</view>
      </view>
    </view>
  </view>

  <view class="metrics-card">
    <view class="metrics-row">
      <view wx:for="{{topMetrics}}" wx:key="key"
        class="metric-item {{item.action ? 'clickable' : ''}}"
        bindtap="topMetricAction" data-action="{{item.action}}">
        <view class="metric-label">{{item.name}}</view>
        <view class="metric-value">{{item.value}}</view>
        <view wx:if="{{item.action}}" class="metric-action">></view>
      </view>
    </view>
  </view>

  <view class="ai-banner" bindtap="goToDiagnosis">
    <view class="banner-row">
      <view class="banner-title">
        <text class="star">★</text>
        <text>AI日报</text>
      </view>
      <text class="banner-action">深度解读 ></text>
    </view>
    <view class="banner-content">今日消耗5000元，转化23个，成本上涨，点击深度解读查看原因及建议</view>
    <view class="banner-time">数据周期：5月14日 17:56</view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <text class="section-title">今日数据概览</text>
      <view class="custom-btn" bindtap="openMetricPicker">
        <text>切换指标</text>
      </view>
    </view>
    <view class="metrics-scroll">
      <view class="metrics-list">
        <view wx:for="{{selectedMetrics}}" wx:key="key"
          class="metric-card {{selectedIndex === index ? 'active' : ''}}"
          bindtap="selectMetric" data-index="{{index}}">
          <view class="card-label">{{item.name}}</view>
          <view class="card-value">{{item.value}}</view>
          <view class="card-change">{{item.change}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="chart-card">
    <view class="chart-header">
      <text class="chart-title">{{chartTitle}}</text>
    </view>
    <view class="line-chart">
      <view class="chart-y-axis">
        <view class="y-label">30</view>
        <view class="y-label">15</view>
        <view class="y-label">0</view>
      </view>
      <view class="chart-body">
        <view class="chart-grid">
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>
        </view>
        <view class="line-area" style="height: {{lineAreaHeight}}%; background: {{lineAreaColor}};"></view>
        <view class="line-dots">
          <view wx:for="{{chartData}}" wx:key="label" class="dot-col">
            <view class="dot" style="bottom: {{item.dotBottom}}%; background: {{item.dotColor}};"></view>
            <view class="dot-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showMetricPicker}}" class="picker-mask" bindtap="closeMetricPicker">
    <view class="picker-container" catchtap="">
      <view class="picker-header">
        <text class="picker-title">选择指标</text>
        <text class="picker-close" bindtap="closeMetricPicker">✕</text>
      </view>
      <scroll-view class="picker-scroll" scroll-y="true">
        <view wx:for="{{pickerDisplayList}}" wx:key="key" wx:for-item="cat">
          <view class="category-title">{{cat.name}}</view>
          <view class="metric-options">
            <view wx:for="{{cat.list}}" wx:key="key" wx:for-item="m"
              class="metric-option {{m.selected ? 'selected' : ''}}"
              bindtap="toggleMetric" data-key="{{m.key}}" data-category="{{cat.key}}">
              <text class="option-name">{{m.name}}</text>
              <view wx:if="{{m.selected}}" class="option-check">✓</view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="picker-footer">
        <text class="picker-hint">已选择 {{selectedMetrics.length}}/6 个指标</text>
        <view class="picker-save" bindtap="saveMetrics">保存</view>
      </view>
    </view>
  </view>
</view>