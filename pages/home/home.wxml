<view class="container">
  <view class="header">
    <view class="header-top">
      <view class="header-left" bindtap="goToProfile">
        <view class="avatar">👤</view>
        <text class="profile-link">个人中心</text>
      </view>
      <view class="switch-btn" bindtap="goToAccountSelect">
        <text class="switch-icon">⇄</text>
        <text class="switch-text">切换</text>
      </view>
    </view>
    <view class="account-name">{{accountName}}</view>
  </view>

  <view class="metrics-card">
    <view class="metrics-row">
      <view class="metric-item">
        <view class="metric-label">当前余额</view>
        <view class="metric-value">100,000.00</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">今日消耗</view>
        <view class="metric-value">5,000.00</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">有消耗账户</view>
        <view class="metric-value">15/27</view>
      </view>
    </view>
    <view class="metrics-row metrics-row-secondary">
      <view class="metric-item">
        <view class="metric-label">曝光量<text class="up">↑</text></view>
        <view class="metric-value blue">4,555</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">点击量<text class="down">↓</text></view>
        <view class="metric-value blue">123</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">转化量<text class="down">↓</text></view>
        <view class="metric-value blue">23</view>
      </view>
    </view>
  </view>

  <view class="ai-banner" bindtap="goToDiagnosis">
    <view class="banner-row">
      <view class="banner-title">
        <text class="star">★</text>
        <text>AI日报</text>
      </view>
      <text class="banner-action">深度解读 ></text>
    </view>
    <view class="banner-content">今日消耗5000元，转化23个，成本上涨，点击深度解读查看原因及建议</view>
    <view class="banner-time">数据周期：5月14日 17:56</view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <text class="section-title">数据概览</text>
      <view class="date-picker">
        <text>今天</text>
        <text class="arrow">▼</text>
      </view>
    </view>
    <view class="metrics-scroll">
      <view class="metrics-list">
        <view wx:for="{{overviewMetrics}}" wx:key="name"
          class="metric-card {{selectedIndex === index ? 'active' : ''}}"
          bindtap="selectMetric" data-index="{{index}}">
          <view class="card-label">{{item.name}}</view>
          <view class="card-value">{{item.value}}</view>
          <view class="card-change">{{item.change}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="chart-card">
    <view class="chart-header">
      <text class="chart-title">{{chartTitle}}</text>
      <view class="chart-tabs">
        <text class="chart-tab {{chartType === 'consume' ? 'active' : ''}}" bindtap="switchChart" data-type="consume">消耗</text>
        <text class="chart-tab {{chartType === 'convert' ? 'active' : ''}}" bindtap="switchChart" data-type="convert">转化</text>
      </view>
    </view>

    <view class="line-chart">
      <view class="chart-y-axis">
        <view class="y-label">30</view>
        <view class="y-label">15</view>
        <view class="y-label">0</view>
      </view>
      <view class="chart-body">
        <view class="chart-grid">
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>
        </view>
        <view class="line-area" style="height: {{lineAreaHeight}}%; background: {{lineAreaColor}};"></view>
        <view class="line-dots">
          <view wx:for="{{chartData}}" wx:key="label" class="dot-col">
            <view class="dot" style="bottom: {{item.dotBottom}}%; background: {{item.dotColor}};"></view>
            <view class="dot-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>