.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.header {
  background: #0066FF;
  padding: 88rpx 32rpx 32rpx;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.switch-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.switch-icon {
  font-size: 32rpx;
  color: #fff;
}

.profile-icon {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
}

.profile-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.profile-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-left: 8rpx;
}

.metrics-card {
  background: #fff;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.metrics-row {
  display: flex;
}

.metrics-row-secondary {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f1f5;
}

.metric-item {
  flex: 1;
  text-align: center;
}

.metric-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #191919;
}

.metric-value.blue {
  color: #0066FF;
}

.up { color: #00C853; margin-left: 4rpx; }
.down { color: #FF3B30; margin-left: 4rpx; }

.ai-banner {
  background: #FFF7E6;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255,149,0,0.15);
}

.banner-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.banner-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #B66D00;
}

.star {
  color: #FF9500;
  margin-right: 8rpx;
}

.banner-action {
  font-size: 24rpx;
  color: #FF9500;
}

.banner-content {
  font-size: 24rpx;
  color: #865A00;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.banner-time {
  font-size: 22rpx;
  color: #C48600;
}

.section-card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #191919;
}

.date-picker {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #0066FF;
}

.arrow {
  margin-left: 4rpx;
  font-size: 20rpx;
}

.metrics-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.metrics-list {
  display: inline-flex;
  gap: 16rpx;
}

.metric-card {
  min-width: 200rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.metric-card.active {
  background: #0066FF;
  border-color: #0066FF;
}

.card-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-card.active .card-label {
  color: rgba(255,255,255,0.85);
}

.card-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 8rpx;
}

.metric-card.active .card-value {
  color: #fff;
}

.card-change {
  font-size: 20rpx;
  color: #00C853;
}

.metric-card.active .card-change {
  color: rgba(255,255,255,0.75);
}

.chart-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
}

.chart-tabs {
  display: flex;
  gap: 24rpx;
}

.chart-tab {
  font-size: 24rpx;
  color: #666;
  position: relative;
  padding-bottom: 8rpx;
}

.chart-tab.active {
  color: #0066FF;
  font-weight: 600;
}

.chart-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #0066FF;
  border-radius: 4rpx;
}

.css-chart {
  display: flex;
  height: 320rpx;
  background: rgba(0,102,255,0.04);
  border-radius: 16rpx;
  padding: 16rpx;
}

.chart-y-axis {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
}

.y-label {
  font-size: 20rpx;
  color: #999;
  text-align: right;
}

.chart-body {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background: #E8EBF0;
}

.chart-bars {
  position: absolute;
  bottom: 36rpx;
  left: 0;
  right: 0;
  top: 0;
  display: flex;
  justify-content: space-around;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-wrapper {
  flex: 1;
  width: 100%;
  position: relative;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 24rpx;
  border-radius: 12rpx 12rpx 0 0;
  margin: 0 auto;
}

.bar-dot {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  left: 50%;
  transform: translateX(-50%);
  margin-bottom: 4rpx;
}

.bar-label {
  font-size: 18rpx;
  color: #999;
  margin-top: 8rpx;
}