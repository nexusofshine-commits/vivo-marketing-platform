.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.header {
  background: #0066FF;
  padding: 88rpx 32rpx 36rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.profile-link {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.switch-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.switch-icon {
  font-size: 28rpx;
  color: #fff;
}

.switch-text {
  font-size: 24rpx;
  color: #fff;
}

.account-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.metrics-card {
  background: #fff;
  margin: -24rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.metrics-row {
  display: flex;
}

.metrics-row-secondary {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f1f5;
}

.metric-item {
  flex: 1;
  text-align: center;
}

.metric-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #191919;
}

.metric-value.blue {
  color: #0066FF;
}

.up { color: #00C853; margin-left: 4rpx; }
.down { color: #FF3B30; margin-left: 4rpx; }

.ai-banner {
  background: #FFF7E6;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255,149,0,0.12);
}

.banner-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.banner-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #B66D00;
}

.star {
  color: #FF9500;
  margin-right: 8rpx;
}

.banner-action {
  font-size: 24rpx;
  color: #FF9500;
}

.banner-content {
  font-size: 24rpx;
  color: #865A00;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.banner-time {
  font-size: 20rpx;
  color: #C48600;
}

.section-card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
}

.date-picker {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #0066FF;
}

.arrow {
  margin-left: 4rpx;
  font-size: 20rpx;
}

.metrics-scroll {
  margin: 0 -4rpx;
}

.metrics-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.metric-card {
  width: calc(33.33% - 12rpx);
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.metric-card.active {
  background: #0066FF;
  border-color: #0066FF;
}

.card-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-card.active .card-label {
  color: rgba(255,255,255,0.85);
}

.card-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 4rpx;
}

.metric-card.active .card-value {
  color: #fff;
}

.card-change {
  font-size: 18rpx;
  color: #00C853;
}

.metric-card.active .card-change {
  color: rgba(255,255,255,0.75);
}

.chart-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
}

.chart-tabs {
  display: flex;
  gap: 24rpx;
}

.chart-tab {
  font-size: 24rpx;
  color: #999;
  position: relative;
  padding-bottom: 8rpx;
}

.chart-tab.active {
  color: #0066FF;
  font-weight: 600;
}

.chart-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #0066FF;
  border-radius: 4rpx;
}

.line-chart {
  display: flex;
  height: 320rpx;
  background: rgba(0,102,255,0.02);
  border-radius: 16rpx;
  padding: 16rpx;
}

.chart-y-axis {
  width: 56rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
}

.y-label {
  font-size: 18rpx;
  color: #bbb;
  text-align: right;
}

.chart-body {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background: #f0f1f5;
}

.line-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 36rpx;
  border-radius: 8rpx 8rpx 0 0;
}

.line-dots {
  position: absolute;
  bottom: 36rpx;
  left: 0;
  right: 0;
  top: 0;
  display: flex;
  justify-content: space-around;
}

.dot-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.dot {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  left: 50%;
  transform: translateX(-50%);
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 2;
}

.dot-label {
  position: absolute;
  bottom: -36rpx;
  font-size: 18rpx;
  color: #999;
  white-space: nowrap;
}