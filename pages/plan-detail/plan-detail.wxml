<view class="container">
  <view class="detail-header">
    <text class="detail-plan-name">唯品会拉新-信息流计划</text>
    <view class="detail-row">
      <view class="detail-info-item">
        <text class="detail-info-label">投放状态</text>
        <text class="detail-info-value running">投放中</text>
      </view>
      <view class="detail-info-item">
        <text class="detail-info-label">投放日期</text>
        <text class="detail-info-value">长期投放</text>
      </view>
      <view class="detail-info-item">
        <text class="detail-info-label">投放时段</text>
        <text class="detail-info-value">全时段</text>
      </view>
      <view class="detail-info-item">
        <text class="detail-info-label">预算</text>
        <text class="detail-info-value">¥5,000/天</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">核心指标</text>
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-value">¥32,450</text>
        <text class="stat-label">花费</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">586w</text>
        <text class="stat-label">曝光</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">26.3w</text>
        <text class="stat-label">点击</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">4.49%</text>
        <text class="stat-label">点击率</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">转化数据</text>
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-value">3,245</text>
        <text class="stat-label">激活数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">9.99</text>
        <text class="stat-label">激活成本</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">1,826</text>
        <text class="stat-label">次留数</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">数据趋势</text>
    <view class="line-chart">
      <view class="chart-y-axis">
        <view class="y-label">52</view>
        <view class="y-label">26</view>
        <view class="y-label">0</view>
      </view>
      <view class="chart-body">
        <view class="chart-grid">
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>
        </view>
        <view class="line-area" style="height: {{trendAreaH}}%;"></view>
        <view class="line-dots">
          <view wx:for="{{trendData}}" wx:key="label" class="dot-col">
            <view class="dot" style="bottom: {{item.dotBottom}}%;"></view>
            <view class="dot-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>