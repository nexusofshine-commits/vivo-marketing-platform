.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 100rpx;
}

.detail-header {
  background: #0066FF;
  padding: 40rpx 24rpx 60rpx;
  color: #FFFFFF;
  position: relative;
}

.detail-plan-name {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
  display: block;
}

.detail-basic-info {
  display: flex;
  justify-content: space-between;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.detail-info-item {
  display: flex;
  flex-direction: column;
  flex: 1;
  text-align: center;
}

.detail-info-label {
  font-size: 20rpx;
  opacity: 0.8;
  margin-bottom: 6rpx;
}

.detail-info-value {
  font-size: 28rpx;
  font-weight: 700;
}

.detail-conversion {
  padding: 24rpx;
  background-color: #FFFFFF;
  margin: -32rpx 24rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.conversion-grid {
  display: flex;
  justify-content: space-between;
}

.conversion-card {
  background-color: #FFFFFF;
  padding: 20rpx;
  text-align: center;
  flex: 1;
  margin: 0 8rpx;
  border-radius: 16rpx;
  border: 1rpx solid #f0f1f5;
}

.conversion-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #0066FF;
  display: block;
  margin-bottom: 6rpx;
}

.conversion-label {
  font-size: 20rpx;
  color: #999999;
  display: block;
}

.stats-card {
  background-color: #FFFFFF;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
}

.stats-date {
  font-size: 22rpx;
  color: #0066FF;
  background: rgba(0,102,255,0.05);
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  flex-direction: column;
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #191919;
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999999;
}

.chart-card {
  background-color: #FFFFFF;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.chart-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.css-chart {
  display: flex;
  height: 320rpx;
  background: rgba(0,102,255,0.04);
  border-radius: 16rpx;
  padding: 16rpx;
}

.chart-y-axis {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
}

.y-label {
  font-size: 20rpx;
  color: #999;
  text-align: right;
}

.chart-body {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background: #E8EBF0;
}

.chart-bars {
  position: absolute;
  bottom: 36rpx;
  left: 0;
  right: 0;
  top: 0;
  display: flex;
  justify-content: space-around;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-wrapper {
  flex: 1;
  width: 100%;
  position: relative;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 24rpx;
  border-radius: 12rpx 12rpx 0 0;
  margin: 0 auto;
}

.bar-dot {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  left: 50%;
  transform: translateX(-50%);
  margin-bottom: 4rpx;
}

.bar-label {
  font-size: 18rpx;
  color: #999;
  margin-top: 8rpx;
}
