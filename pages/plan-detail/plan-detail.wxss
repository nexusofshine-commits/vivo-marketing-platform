.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.detail-header {
  background: #0066FF;
  padding: 88rpx 32rpx 36rpx;
  color: #fff;
}

.detail-plan-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-info-item {
  background: rgba(255,255,255,0.15);
  border-radius: 10rpx;
  padding: 10rpx 16rpx;
}

.detail-info-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-bottom: 4rpx;
}

.detail-info-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.detail-info-value.running {
  color: #69F0AE;
}

.section-card {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.stat-row {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #191919;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

.line-chart {
  display: flex;
  height: 280rpx;
  background: rgba(0,102,255,0.02);
  border-radius: 16rpx;
  padding: 16rpx;
}

.chart-y-axis {
  width: 56rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
}

.y-label {
  font-size: 18rpx;
  color: #bbb;
  text-align: right;
}

.chart-body {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background: #f0f1f5;
}

.line-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 36rpx;
  background: rgba(0,102,255,0.06);
  border-radius: 8rpx 8rpx 0 0;
}

.line-dots {
  position: absolute;
  bottom: 36rpx;
  left: 0;
  right: 0;
  top: 0;
  display: flex;
  justify-content: space-around;
}

.dot-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #0066FF;
  left: 50%;
  transform: translateX(-50%);
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
  z-index: 2;
}

.dot-label {
  position: absolute;
  bottom: -36rpx;
  font-size: 16rpx;
  color: #999;
  white-space: nowrap;
}