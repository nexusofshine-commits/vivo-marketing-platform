.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.profile-header {
  background-color: #FFFFFF;
  padding: 60rpx 24rpx 48rpx;
  text-align: center;
  border-bottom: 1rpx solid #e8ebf0;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin: 0 auto 24rpx;
  color: #0066FF;
  background: rgba(0,102,255,0.08);
  border-radius: 32rpx;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #191919;
  display: block;
  margin-bottom: 10rpx;
}

.profile-desc {
  font-size: 26rpx;
  color: #666666;
  display: block;
}

.profile-menu {
  background-color: #FFFFFF;
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
  background: #FFFFFF;
}

.menu-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 1rpx;
  background-color: #f0f1f5;
}

.menu-item:last-child::after {
  display: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  background: rgba(0,102,255,0.05);
  border-radius: 14rpx;
  color: #0066FF;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #191919;
  font-weight: 500;
}

.menu-arrow {
  color: #999999;
  font-size: 26rpx;
}
