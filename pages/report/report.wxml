<view class="container">
  <view class="navbar">
    <text class="navbar-title">数据报表</text>
  </view>

  <view class="dim-tabs">
    <text class="dim-tab {{currentTab === 'overview' ? 'active' : ''}}" bindtap="switchTab" data-tab="overview">概览</text>
    <text class="dim-tab {{currentTab === 'plan' ? 'active' : ''}}" bindtap="switchTab" data-tab="plan">计划</text>
    <text class="dim-tab {{currentTab === 'account' ? 'active' : ''}}" bindtap="switchTab" data-tab="account">账户</text>
    <text class="dim-tab {{currentTab === 'creative' ? 'active' : ''}}" bindtap="switchTab" data-tab="creative">创意</text>
  </view>

  <view class="date-bar">
    <text class="date-btn {{currentDate === 'today' ? 'active' : ''}}" bindtap="switchDate" data-date="today">今日</text>
    <text class="date-btn {{currentDate === '7days' ? 'active' : ''}}" bindtap="switchDate" data-date="7days">近7日</text>
    <text class="date-btn {{currentDate === '30days' ? 'active' : ''}}" bindtap="switchDate" data-date="30days">近30日</text>
    <text class="date-btn {{currentDate === 'custom' ? 'active' : ''}}" bindtap="switchDate" data-date="custom">自定义</text>
  </view>

  <view class="stat-row">
    <view class="stat-item">
      <text class="stat-value">102,450</text>
      <text class="stat-label">总花费(元)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">1,825w</text>
      <text class="stat-label">总曝光</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">84.6w</text>
      <text class="stat-label">总点击</text>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">消耗趋势</text>
    <view class="line-chart">
      <view class="chart-y-axis">
        <view class="y-label">52</view>
        <view class="y-label">26</view>
        <view class="y-label">0</view>
      </view>
      <view class="chart-body">
        <view class="chart-grid">
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>
        </view>
        <view class="line-area" style="height: {{trendAreaH}}%;"></view>
        <view class="line-dots">
          <view wx:for="{{trendData}}" wx:key="label" class="dot-col">
            <view class="dot" style="bottom: {{item.dotBottom}}%;"></view>
            <view class="dot-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">转化效果</text>
    <view class="line-chart">
      <view class="chart-y-axis">
        <view class="y-label">86</view>
        <view class="y-label">43</view>
        <view class="y-label">0</view>
      </view>
      <view class="chart-body">
        <view class="chart-grid">
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>
        </view>
        <view class="line-area" style="height: {{convAreaH}}%; background: rgba(0,200,83,0.06);"></view>
        <view class="line-dots">
          <view wx:for="{{conversionData}}" wx:key="label" class="dot-col">
            <view class="dot dot-blue" style="bottom: {{item.actBottom}}%;"></view>
            <view class="dot dot-green" style="bottom: {{item.retBottom}}%;"></view>
            <view class="dot-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
    <view class="chart-legend">
      <view class="legend-item"><view class="legend-dot blue"></view><text>激活</text></view>
      <view class="legend-item"><view class="legend-dot green"></view><text>留存</text></view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">计划列表</text>
    <view class="list-item" bindtap="goToDetail">
      <view class="item-left">
        <view class="item-icon" style="background:#E8F0FF;color:#0F62FE;">📋</view>
        <view class="item-info">
          <text class="item-name">唯品会拉新-信息流计划</text>
          <text class="item-meta">OCPC · 投放中</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-value">32,450</text>
        <text class="item-unit">花费(元)</text>
      </view>
    </view>
    <view class="list-item" bindtap="goToDetail">
      <view class="item-left">
        <view class="item-icon" style="background:#E8F0FF;color:#0F62FE;">📋</view>
        <view class="item-info">
          <text class="item-name">唯品会拉新-开屏计划</text>
          <text class="item-meta">OCPC · 投放中</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-value">28,120</text>
        <text class="item-unit">花费(元)</text>
      </view>
    </view>
    <view class="list-item" bindtap="goToDetail">
      <view class="item-left">
        <view class="item-icon" style="background:#FFF3E0;color:#FF832B;">📋</view>
        <view class="item-info">
          <text class="item-name">唯品会拉活-信息流计划</text>
          <text class="item-meta">OCPC · 已暂停</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-value">18,680</text>
        <text class="item-unit">花费(元)</text>
      </view>
    </view>
  </view>
</view>