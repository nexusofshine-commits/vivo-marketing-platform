.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 100rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #191919;
}

.report-tabs {
  background-color: #FFFFFF;
  display: flex;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #e8ebf0;
}

.report-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666666;
  position: relative;
  font-weight: 500;
}

.report-tab.active {
  color: #0066FF;
}

.report-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  background-color: #0066FF;
  border-radius: 3rpx;
}

.report-content {
  padding: 24rpx;
}

.report-header {
  background-color: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
}

.date-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.date-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #666666;
  border: 1rpx solid #e8ebf0;
  border-radius: 12rpx;
}

.date-btn.active {
  background-color: #0066FF;
  color: #FFFFFF;
  border-color: #0066FF;
}

.report-summary {
  display: flex;
  justify-content: space-between;
}

.report-stat {
  display: flex;
  flex-direction: column;
  flex: 1;
  text-align: center;
}

.report-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 8rpx;
}

.report-stat-label {
  font-size: 22rpx;
  color: #999999;
}

.chart-card {
  background-color: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
}

.chart-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.css-chart {
  display: flex;
  height: 280rpx;
  background: linear-gradient(180deg, rgba(0,102,255,0.06) 0%, rgba(0,102,255,0.01) 100%);
  border-radius: 16rpx;
  padding: 16rpx;
}

.chart-y-axis {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
}

.y-label {
  font-size: 18rpx;
  color: #999;
  text-align: right;
}

.chart-body {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background: #E8EBF0;
}

.chart-bars {
  position: absolute;
  bottom: 36rpx;
  left: 0;
  right: 0;
  top: 0;
  display: flex;
  justify-content: space-around;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-wrapper {
  flex: 1;
  width: 100%;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
}

.bar {
  width: 20rpx;
  border-radius: 10rpx 10rpx 0 0;
}

.bar-blue {
  background: #0066FF;
}

.bar-green {
  background: #00C853;
}

.bar-label {
  font-size: 16rpx;
  color: #999;
  margin-top: 8rpx;
}

.report-list {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
}

.report-list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f1f5;
}

.report-list-item:last-child {
  border-bottom: none;
}

.report-list-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  border: 1rpx solid #e8ebf0;
  border-radius: 16rpx;
  color: #0066FF;
  background: rgba(0,102,255,0.05);
}

.report-list-info {
  flex: 1;
}

.report-list-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #191919;
  display: block;
  margin-bottom: 6rpx;
}

.report-list-meta {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.report-list-data {
  text-align: right;
}

.report-list-data-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0066FF;
  display: block;
  margin-bottom: 4rpx;
}

.report-list-data-label {
  font-size: 20rpx;
  color: #999999;
  display: block;
}