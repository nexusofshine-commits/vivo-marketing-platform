.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f1f5;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
}

.dim-tabs {
  background: #fff;
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #f0f1f5;
}

.dim-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e8ebf0;
  border-radius: 12rpx;
  font-weight: 500;
}

.dim-tab.active {
  background: #0066FF;
  color: #fff;
  border-color: #0066FF;
}

.date-bar {
  background: #fff;
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.date-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e8ebf0;
  border-radius: 10rpx;
}

.date-btn.active {
  background: #0066FF;
  color: #fff;
  border-color: #0066FF;
}

.stat-row {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #191919;
  display: block;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

.section-card {
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 20rpx;
  display: block;
}

.line-chart {
  display: flex;
  height: 280rpx;
  background: rgba(0,102,255,0.02);
  border-radius: 16rpx;
  padding: 16rpx;
}

.chart-y-axis {
  width: 56rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
}

.y-label {
  font-size: 18rpx;
  color: #bbb;
  text-align: right;
}

.chart-body {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background: #f0f1f5;
}

.line-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 36rpx;
  background: rgba(0,102,255,0.06);
  border-radius: 8rpx 8rpx 0 0;
}

.line-dots {
  position: absolute;
  bottom: 36rpx;
  left: 0;
  right: 0;
  top: 0;
  display: flex;
  justify-content: space-around;
}

.dot-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #0066FF;
  left: 50%;
  transform: translateX(-50%);
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
  z-index: 2;
}

.dot-blue { background: #0066FF; }
.dot-green { background: #00C853; }

.dot-label {
  position: absolute;
  bottom: -36rpx;
  font-size: 16rpx;
  color: #999;
  white-space: nowrap;
}

.chart-legend {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.blue { background: #0066FF; }
.legend-dot.green { background: #00C853; }

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}

.list-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  font-size: 22rpx;
  color: #999;
}

.item-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0066FF;
  display: block;
  margin-bottom: 4rpx;
}

.item-unit {
  font-size: 20rpx;
  color: #999;
}