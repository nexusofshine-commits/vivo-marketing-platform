.container {
  padding-bottom: 120rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #E5E7EB;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.plan-tabs {
  background-color: #FFFFFF;
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.plan-tab {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #666666;
  border: 1rpx solid #E5E7EB;
  font-weight: 500;
}

.plan-tab.active {
  background-color: #111111;
  color: #FFFFFF;
  border-color: #111111;
}

.plan-list {
  padding: 16rpx 0;
}

.plan-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.plan-info {
  flex: 1;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  display: block;
  margin-bottom: 8rpx;
}

.plan-meta {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.plan-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border: 1rpx solid;
}

.status-running {
  border-color: #00A870;
  color: #00A870;
}

.status-paused {
  border-color: #FF832B;
  color: #FF832B;
}

.status-stopped {
  border-color: #999999;
  color: #999999;
}

.plan-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #E5E7EB;
  border-bottom: 1rpx solid #E5E7EB;
  margin-bottom: 24rpx;
}

.plan-stat {
  display: flex;
  flex-direction: column;
}

.plan-stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 4rpx;
}

.plan-stat-label {
  font-size: 22rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.plan-actions {
  display: flex;
  gap: 16rpx;
}

.plan-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  border: 1rpx solid #E5E7EB;
  color: #111111;
  font-weight: 500;
}

.plan-btn.btn-primary {
  background-color: #0F62FE;
  color: #FFFFFF;
  border-color: #0F62FE;
}

.stats-card {
  background-color: #FFFFFF;
  padding: 40rpx 32rpx;
  margin: 16rpx 0;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.diagnosis-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin: 16rpx 0;
}

.diagnosis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.diagnosis-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.diagnosis-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.diagnosis-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background-color: #F8F9FA;
  border-radius: 16rpx;
}

.diagnosis-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.diagnosis-content {
  flex: 1;
}

.diagnosis-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
  display: block;
  margin-bottom: 8rpx;
}

.diagnosis-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
}

.diagnosis-arrow {
  color: #999999;
  font-size: 28rpx;
  margin-left: 16rpx;
}