        <text class="account-name">唯品会拉活A</text>
        <text class="account-email">weipinhuicpc@weipinhui.com</text>
      </view>
      <text class="account-status status-available">可用</text>
    </view>
    <view class="account-card">
      <view class="account-icon">🎯</view>
      <view class="account-info">
        <text class="account-name">唯品会拉活B</text>
        <text class="account-email">weipinhuicpc@weipinhui.com</text>
      </view>
      <text class="account-status status-frozen">冻结</text>
    </view>
  </view>
