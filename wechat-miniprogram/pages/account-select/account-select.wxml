  <view class="account-group">
    <text class="group-label">投放账号</text>
    <view class="account-card" bindtap="selectAccount" data-name="唯品会拉新A">
      <view class="account-icon">🎯</view>
      <view class="account-info">
        <text class="account-name">唯品会拉新A</text>
        <text class="account-email">weipinhuicpc@weipinhui.com</text>
      </view>
      <text class="account-status status-available">可用</text>
    </view>
    <view class="account-card" bindtap="selectAccount" data-name="唯品会拉新B">
      <view class="account-icon">🎯</view>
      <view class="account-info">
