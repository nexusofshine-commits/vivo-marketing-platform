.container {
  padding-bottom: 0;
}

.header {
  background-color: #FFFFFF;
  padding: 48rpx 32rpx 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #111111;
}

.account-group {
  margin-bottom: 16rpx;
}

.group-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  padding: 40rpx 32rpx 16rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  font-weight: 500;
}

.account-card {
  background-color: #FFFFFF;
  margin: 0 32rpx 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  border-radius: 0;
  position: relative;
}

.account-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 0;
  height: 1rpx;
  background-color: #E5E7EB;
}

.account-card:last-child::after {
  display: none;
}

.account-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #E8F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.account-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.account-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #111111;
  margin-bottom: 6rpx;
}

.account-email {
  font-size: 26rpx;
  color: #666666;
}

.account-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  margin-left: 16rpx;
  border: 1rpx solid;
}

.status-available {
  color: #0F62FE;
  border-color: #0F62FE;
}

.status-frozen {
  color: #999999;
  border-color: #E5E7EB;
  background-color: #F8F9FA;
}