.container {
  padding-bottom: 120rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #E5E7EB;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.diagnosis-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin: 16rpx 0;
}

.diagnosis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.diagnosis-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.diagnosis-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.diagnosis-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background-color: #F8F9FA;
  border-radius: 16rpx;
}

.diagnosis-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.diagnosis-icon.warning {
  background-color: #FFF3E0;
  color: #FF832B;
}

.diagnosis-icon.error {
  background-color: #FFEBEE;
  color: #DA1E28;
}

.diagnosis-icon.info {
  background-color: #E8F0FF;
  color: #0F62FE;
}

.diagnosis-content {
  flex: 1;
}

.diagnosis-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
  display: block;
  margin-bottom: 8rpx;
}

.diagnosis-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
}

.diagnosis-arrow {
  color: #999999;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.diagnosis-detail {
  display: none;
  padding: 24rpx;
  background-color: #F8F9FA;
  margin-top: -8rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.diagnosis-detail.show {
  display: block;
}

.detail-content {
  margin-bottom: 16rpx;
}

.detail-content:last-child {
  margin-bottom: 0;
}

.detail-title {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 4rpx;
}