.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 32rpx;
  padding-bottom: 0;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 40rpx;
}

.diagnosis-section {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 32rpx;
}

.diagnosis-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.diagnosis-item {
  border: 2rpx solid #e8ebf0;
  border-radius: 24rpx;
  overflow: hidden;
}

.diagnosis-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #fafbfc;
}

.diagnosis-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 28rpx;
}

.diagnosis-icon.warning {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.diagnosis-icon.info {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.diagnosis-icon.error {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.diagnosis-info {
  flex: 1;
}

.diagnosis-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 8rpx;
}

.diagnosis-time {
  font-size: 24rpx;
  color: #999999;
}

.diagnosis-arrow {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.3s;
}

.diagnosis-arrow.open {
  transform: rotate(180deg);
}

.diagnosis-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s;
}

.diagnosis-detail.open {
  max-height: 2000rpx;
}

.detail-section {
  padding: 32rpx;
  border-bottom: 2rpx solid #f5f6fa;
}

.detail-section:last-child {
  border-bottom: none;
  padding-bottom: 32rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  padding: 32rpx;
  background: #fafbfc;
  border-top: 2rpx solid #f0f1f5;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 180rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
  background: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #f5f6fa;
  color: #333333;
}

.action-btn.outline {
  background: transparent;
  color: #0066FF;
  border: 2rpx solid #0066FF;
}

.action-btn.success {
  background: linear-gradient(135deg, #00C853 0%, #00A854 100%);
  color: #FFFFFF;
}

.action-btn.danger {
  background: linear-gradient(135deg, #FF3B30 0%, #E02D27 100%);
  color: #FFFFFF;
}

.tab-spacer {
  height: 120rpx;
}
