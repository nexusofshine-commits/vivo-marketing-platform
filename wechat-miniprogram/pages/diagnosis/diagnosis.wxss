.container {
  min-height: 100vh;
  background: #F5F6F7;
  padding: 24rpx;
  padding-bottom: 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 32rpx;
}

.diagnosis-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.diagnosis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.diagnosis-item {
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  overflow: hidden;
}

.diagnosis-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F9FAFB;
}

.diagnosis-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.diagnosis-icon.warning {
  background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
}

.diagnosis-icon.info {
  background: linear-gradient(135deg, #60A5FA 0%, #3B82F6 100%);
}

.diagnosis-icon.error {
  background: linear-gradient(135deg, #F87171 0%, #EF4444 100%);
}

.diagnosis-info {
  flex: 1;
}

.diagnosis-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.diagnosis-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.diagnosis-arrow {
  font-size: 24rpx;
  color: #9CA3AF;
  transition: transform 0.3s;
}

.diagnosis-arrow.open {
  transform: rotate(180deg);
}

.diagnosis-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s;
}

.diagnosis-detail.open {
  max-height: 1000rpx;
}

.detail-section {
  padding: 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.detail-section:last-child {
  border-bottom: none;
  padding-bottom: 24rpx;
}

.detail-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.detail-content {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 快捷操作按钮 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #FAFAFA;
  border-top: 1rpx solid #F3F4F6;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
  background: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0F62FE 0%, #054ADA 100%);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #F3F4F6;
  color: #374151;
}

.action-btn.outline {
  background: transparent;
  color: #0F62FE;
  border: 2rpx solid #0F62FE;
}

.action-btn.success {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #FFFFFF;
}

.action-btn.danger {
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
  color: #FFFFFF;
}

.tab-spacer {
  height: 120rpx;
}