<view class="container">
  <!-- 账户信息栏 -->
  <view class="account-bar">
    <view class="account-avatar" bindtap="goToAccountSelect">
      <text class="avatar-icon">👤</text>
    </view>
    <view class="account-info" bindtap="goToAccountSelect">
      <view class="account-name">{{accountName}}</view>
      <view class="account-switch">点击切换账户</view>
    </view>
    <view class="user-avatar" bindtap="goToProfile">
      <text class="user-icon">⚙️</text>
    </view>
  </view>

  <!-- 账户指标 -->
  <view class="account-metrics">
    <view class="metrics-header">
      <view class="metrics-title">全部账户 ></view>
      <view class="metrics-action">指标 ></view>
    </view>
    
    <view class="top-metrics">
      <view class="top-metric-item">
        <view class="metric-label">当前余额</view>
        <view class="metric-value">100000.00</view>
      </view>
      <view class="top-metric-item">
        <view class="metric-label">今日消耗</view>
        <view class="metric-value">5000.00</view>
      </view>
      <view class="top-metric-item">
        <view class="metric-label">有消耗账户</view>
        <view class="metric-value">15/27个</view>
      </view>
    </view>
    
    <view class="bottom-metrics">
      <view class="bottom-metric-item">
        <view class="metric-label">
          曝光量
          <text class="trend-arrow up">▲</text>
        </view>
        <view class="metric-value">4555</view>
      </view>
      <view class="bottom-metric-item">
        <view class="metric-label">
          点击量
          <text class="trend-arrow down">▼</text>
        </view>
        <view class="metric-value">123</view>
      </view>
      <view class="bottom-metric-item">
        <view class="metric-label">
          转化量
          <text class="trend-arrow down">▼</text>
        </view>
        <view class="metric-value">23</view>
      </view>
    </view>
  </view>

  <!-- AI日报 Banner -->
  <view class="ai-banner" bindtap="goToDiagnosis">
    <view class="banner-header">
      <view class="banner-title">
        <text class="banner-icon">✨</text>
        AI日报
      </view>
      <view class="banner-action">深度解读 ></view>
    </view>
    <view class="banner-content">
      今日消耗5000元，转化23个，成本上涨，点击深度解读查看原因及建议
    </view>
    <view class="banner-time">数据周期：5月14日 17:56</view>
  </view>

  <!-- 数据概览 -->
  <view class="data-overview">
    <view class="overview-header">
      <view class="overview-title">数据概览</view>
      <view class="overview-tabs">
        <view class="date-tab active">今天</view>
        <view class="date-tab">▼</view>
      </view>
    </view>
    
    <scroll-view class="metric-cards-scroll" scroll-x="true">
      <view class="metric-cards">
        <view 
          wx:for="{{overviewMetrics}}" 
          wx:key="name"
          class="metric-card {{selectedMetricIndex === index ? 'active' : ''}}"
          bindtap="selectMetric"
          data-index="{{index}}"
        >
          <view class="card-label">{{item.name}}</view>
          <view class="card-value">{{item.value}}</view>
          <view class="card-change">{{item.change}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 趋势图 -->
  <view class="chart-section">
    <view class="chart-header">
      <view class="chart-title">{{overviewMetrics[selectedMetricIndex].name}}趋势</view>
      <view class="chart-tabs">
        <view 
          class="chart-tab {{chartType === 'consume' ? 'active' : ''}}" 
          bindtap="switchChartTab" 
          data-type="consume"
        >消耗</view>
        <view 
          class="chart-tab {{chartType === 'convert' ? 'active' : ''}}" 
          bindtap="switchChartTab" 
          data-type="convert"
        >转化</view>
      </view>
    </view>
    <view class="chart-container">
      <canvas canvas-id="homeChart" class="home-chart"></canvas>
    </view>
  </view>

  <view class="tab-spacer"></view>
</view>