.container {
  padding-bottom: 120rpx;
}

.home-header {
  background-color: #FFFFFF;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.home-avatar {
  width: 88rpx;
  height: 88rpx;
  background-color: #E8F0FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.home-account-info {
  flex: 1;
}

.home-account-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
  display: block;
  margin-bottom: 6rpx;
}

.home-account-tag {
  font-size: 24rpx;
  color: #666666;
}

.stats-card {
  background-color: #FFFFFF;
  padding: 40rpx 32rpx;
  margin: 16rpx 0;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.stats-date {
  font-size: 24rpx;
  color: #999999;
  border: 1rpx solid #E5E7EB;
  padding: 8rpx 16rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111111;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
  margin-bottom: 4rpx;
}

.stat-trend {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.trend-up {
  color: #DA1E28;
}

.trend-down {
  color: #00A870;
}

.chart-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 32rpx;
  display: block;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
}