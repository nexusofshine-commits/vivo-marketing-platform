.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.account-header {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  padding: 44rpx 20rpx 20rpx;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.account-name {
  font-size: 18px;
  font-weight: 600;
  color: #FFFFFF;
  flex: 1;
  font-size: 36rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon image {
  width: 36rpx;
  height: 36rpx;
}

.profile-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  font-size: 12px;
  color: rgba(255,255,255,0.75);
  font-size: 24rpx;
}

.profile-icon {
  width: 24rpx;
  height: 24rpx;
}

.metrics-card {
  background: #ffffff;
  margin: -24rpx 16rpx 12rpx;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  position: relative;
  z-index: 10;
}

.metrics-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e8ebf0;
}

.metric-item {
  text-align: center;
  flex: 1;
}

.metric-item .label {
  color: #666666;
  font-size: 12px;
  margin-bottom: 6rpx;
  font-size: 24rpx;
}

.metric-item .value {
  color: #191919;
  font-size: 18px;
  font-weight: 700;
  font-size: 36rpx;
}

.metrics-bottom {
  display: flex;
  justify-content: space-between;
}

.metric-bottom-item {
  text-align: center;
  flex: 1;
}

.metric-bottom-item .label {
  color: #666666;
  font-size: 13px;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  font-size: 26rpx;
}

.metric-bottom-item .value {
  color: #0066FF;
  font-size: 22px;
  font-weight: 700;
  font-size: 44rpx;
}

.trend-up { color: #00C853; font-size: 12px; font-size: 24rpx; }
.trend-down { color: #FF3B30; font-size: 12px; font-size: 24rpx; }

.ai-banner {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDCC 100%);
  margin: 0 16rpx 12rpx;
  border-radius: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(255,149,0,0.15);
}

.banner-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.banner-title {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #B66D00;
  font-weight: 600;
  font-size: 13px;
  font-size: 26rpx;
}

.banner-icon {
  font-size: 16px;
}

.banner-action {
  color: #FF9500;
  font-size: 12px;
  font-size: 24rpx;
}

.banner-content {
  color: #865A00;
  font-size: 12px;
  line-height: 1.5;
  margin-bottom: 6rpx;
  font-size: 24rpx;
}

.banner-time {
  color: #C48600;
  font-size: 11px;
  font-size: 22rpx;
}

.section-card {
  background: #ffffff;
  margin: 0 16rpx 12rpx;
  border-radius: 16rpx;
  padding: 18rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  color: #191919;
  font-size: 15px;
  font-weight: 600;
  font-size: 30rpx;
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #0066FF;
  font-size: 12px;
  font-weight: 500;
  font-size: 24rpx;
}

.date-arrow {
  font-size: 20rpx;
}

.metrics-scroll {
  overflow-x: auto;
  margin: 0 -18rpx;
  padding: 0 18rpx;
}

.metrics-scroll::-webkit-scrollbar {
  display: none;
}

.metrics-list {
  display: flex;
  gap: 10rpx;
}

.metric-card {
  min-width: 100px;
  width: 200rpx;
  background: #f5f6fa;
  border-radius: 10rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.metric-card.active {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  border-color: #0066FF;
}

.metric-card .card-label {
  color: #666666;
  font-size: 11px;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-card.active .card-label {
  color: rgba(255,255,255,0.85);
}

.metric-card .card-value {
  color: #191919;
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 6rpx;
  font-size: 36rpx;
}

.metric-card.active .card-value {
  color: white;
}

.metric-card .card-change {
  color: #00C853;
  font-size: 10px;
  font-size: 20rpx;
}

.metric-card.active .card-change {
  color: rgba(255,255,255,0.7);
}

.chart-section {
  background: #ffffff;
  margin: 0 16rpx 80rpx;
  border-radius: 16rpx;
  padding: 18rpx;
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.chart-title {
  color: #191919;
  font-size: 14px;
  font-weight: 600;
  font-size: 28rpx;
}

.chart-tabs {
  display: flex;
  gap: 14rpx;
}

.chart-tab {
  color: #666666;
  font-size: 12px;
  font-size: 24rpx;
  position: relative;
  padding-bottom: 8rpx;
}

.chart-tab.active {
  color: #0066FF;
  font-weight: 600;
}

.chart-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: #0066FF;
  border-radius: 3rpx;
}

.chart-container {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(180deg, rgba(0,102,255,0.08) 0%, rgba(0,102,255,0.01) 100%);
  border-radius: 12rpx;
}

.home-chart {
  width: 100%;
  height: 100%;
}

.tab-spacer {
  height: 100rpx;
}
