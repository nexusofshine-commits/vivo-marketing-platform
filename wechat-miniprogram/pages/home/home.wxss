.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.account-bar {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  padding: 60rpx 24rpx 40rpx;
  display: flex;
  align-items: center;
}

.account-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-icon {
  font-size: 36rpx;
  color: #fff;
}

.account-info {
  flex: 1;
}

.account-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.account-switch {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-icon {
  font-size: 28rpx;
  color: #fff;
}

.account-metrics {
  background: #ffffff;
  margin: -24rpx 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  position: relative;
  z-index: 10;
}

.metrics-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e8ebf0;
}

.metrics-title {
  font-size: 26rpx;
  color: #191919;
  font-weight: 600;
}

.metrics-action {
  font-size: 24rpx;
  color: #0066FF;
  font-weight: 500;
}

.top-metrics {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.top-metric-item {
  flex: 1;
  text-align: center;
}

.top-metric-item .metric-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 6rpx;
}

.top-metric-item .metric-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #191919;
}

.bottom-metrics {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f1f5;
}

.bottom-metric-item {
  flex: 1;
  text-align: center;
}

.bottom-metric-item .metric-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trend-arrow {
  font-size: 20rpx;
  margin-left: 4rpx;
}

.trend-arrow.up {
  color: #00C853;
}

.trend-arrow.down {
  color: #FF3B30;
}

.bottom-metric-item .metric-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #0066FF;
}

.ai-banner {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDCC 100%);
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255,149,0,0.15);
}

.banner-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #B66D00;
  display: flex;
  align-items: center;
}

.banner-icon {
  margin-right: 8rpx;
}

.banner-action {
  font-size: 24rpx;
  color: #FF9500;
  font-weight: 500;
}

.banner-content {
  font-size: 24rpx;
  color: #865A00;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.banner-time {
  font-size: 20rpx;
  color: #C48600;
}

.data-overview {
  background: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.overview-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.overview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
  flex: 1;
}

.overview-tabs {
  display: flex;
  align-items: center;
}

.date-tab {
  font-size: 24rpx;
  color: #0066FF;
  font-weight: 500;
}

.date-tab:last-child {
  margin-left: 8rpx;
  color: #999999;
}

.metric-cards-scroll {
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.metric-cards {
  display: flex;
  gap: 16rpx;
}

.metric-card {
  min-width: 200rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.metric-card.active {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  border-color: #0066FF;
}

.card-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 8rpx;
  white-space: nowrap;
}

.metric-card.active .card-label {
  color: rgba(255,255,255,0.85);
}

.card-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 4rpx;
}

.metric-card.active .card-value {
  color: #FFFFFF;
}

.card-change {
  font-size: 20rpx;
  color: #00C853;
}

.metric-card.active .card-change {
  color: rgba(255,255,255,0.75);
}

.chart-section {
  background: #FFFFFF;
  margin: 0 24rpx 100rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.chart-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #191919;
}

.chart-tabs {
  display: flex;
  gap: 20rpx;
}

.chart-tab {
  font-size: 24rpx;
  color: #666666;
  position: relative;
  padding-bottom: 8rpx;
}

.chart-tab.active {
  color: #0066FF;
  font-weight: 600;
}

.chart-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: #0066FF;
  border-radius: 3rpx;
}

.chart-container {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(180deg, rgba(0,102,255,0.06) 0%, rgba(0,102,255,0.01) 100%);
  border-radius: 16rpx;
}

.home-chart {
  width: 100%;
  height: 100%;
}

.tab-spacer {
  height: 100rpx;
}
