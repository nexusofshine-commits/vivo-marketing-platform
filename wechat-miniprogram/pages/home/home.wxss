.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.account-bar {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  padding: 100rpx 32rpx 80rpx;
  position: relative;
}

.account-avatar {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
}

.avatar-icon {
  font-size: 48rpx;
  color: #fff;
}

.account-info {
  flex: 1;
}

.account-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.account-switch {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-icon {
  font-size: 36rpx;
  color: #fff;
}

.account-metrics {
  background: #ffffff;
  margin: -40rpx 32rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
  position: relative;
  z-index: 10;
}

.metrics-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 36rpx;
  border-bottom: 2rpx solid #e8ebf0;
}

.metrics-title {
  font-size: 28rpx;
  color: #191919;
  font-weight: 600;
}

.metrics-action {
  font-size: 26rpx;
  color: #0066FF;
  font-weight: 500;
}

.top-metrics {
  display: flex;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.top-metric-item {
  flex: 1;
  text-align: center;
}

.top-metric-item .metric-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.top-metric-item .metric-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #191919;
}

.bottom-metrics {
  display: flex;
  justify-content: space-between;
}

.bottom-metric-item {
  flex: 1;
  text-align: center;
}

.bottom-metric-item .metric-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trend-arrow {
  font-size: 24rpx;
  margin-left: 8rpx;
}

.trend-arrow.up {
  color: #00C853;
}

.trend-arrow.down {
  color: #FF3B30;
}

.bottom-metric-item .metric-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #0066FF;
}

.ai-banner {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDCC 100%);
  margin: 0 32rpx 24rpx;
  border-radius: 32rpx;
  padding: 36rpx;
  border: 2rpx solid rgba(255,149,0,0.15);
}

.banner-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #B66D00;
  display: flex;
  align-items: center;
}

.banner-icon {
  margin-right: 16rpx;
}

.banner-action {
  font-size: 26rpx;
  color: #FF9500;
  font-weight: 500;
}

.banner-content {
  font-size: 26rpx;
  color: #865A00;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.banner-time {
  font-size: 24rpx;
  color: #C48600;
}

.data-overview {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
}

.overview-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.overview-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #191919;
  flex: 1;
}

.overview-tabs {
  display: flex;
  align-items: center;
}

.date-tab {
  font-size: 26rpx;
  color: #0066FF;
  margin-left: 32rpx;
  font-weight: 500;
}

.overview-custom {
  font-size: 24rpx;
  color: #666666;
}

.metric-cards-scroll {
  white-space: nowrap;
  margin: 0 -40rpx;
  padding: 0 40rpx;
}

.metric-cards {
  display: flex;
  gap: 24rpx;
}

.metric-card {
  min-width: 260rpx;
  background: #f5f6fa;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  text-align: center;
  transition: all 0.25s ease;
  border: 4rpx solid transparent;
}

.metric-card.active {
  background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
  border-color: #0066FF;
}

.card-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.metric-card.active .card-label {
  color: rgba(255,255,255,0.8);
}

.card-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 8rpx;
}

.metric-card.active .card-value {
  color: #FFFFFF;
}

.card-change {
  font-size: 22rpx;
  color: #00C853;
}

.metric-card.active .card-change {
  color: rgba(255,255,255,0.7);
}

.chart-section {
  background: #FFFFFF;
  margin: 0 32rpx 120rpx;
  border-radius: 32rpx;
  padding: 40rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #191919;
}

.chart-tabs {
  display: flex;
  gap: 32rpx;
}

.chart-tab {
  font-size: 26rpx;
  color: #666666;
  position: relative;
  padding-bottom: 12rpx;
}

.chart-tab.active {
  color: #0066FF;
  font-weight: 600;
}

.chart-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #0066FF;
  border-radius: 4rpx;
}

.chart-container {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, rgba(0,102,255,0.08) 0%, rgba(0,102,255,0.01) 100%);
  border-radius: 24rpx;
}

.home-chart {
  width: 100%;
  height: 100%;
}

.tab-spacer {
  height: 120rpx;
}
