.container {
  padding-bottom: 120rpx;
}

.detail-header {
  background-color: #0F62FE;
  padding: 48rpx 32rpx;
  color: #FFFFFF;
}

.detail-plan-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  display: block;
}

.detail-basic-info {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.detail-info-item {
  display: flex;
  flex-direction: column;
}

.detail-info-label {
  font-size: 22rpx;
  opacity: 0.7;
  margin-bottom: 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.detail-info-value {
  font-size: 28rpx;
  font-weight: 500;
}

.detail-conversion {
  padding: 32rpx;
  background-color: #FFFFFF;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 24rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.conversion-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.conversion-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  text-align: left;
  border: 1rpx solid #E5E7EB;
}

.conversion-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #111111;
  display: block;
  margin-bottom: 8rpx;
}

.conversion-label {
  font-size: 22rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
  display: block;
}

.stats-card {
  background-color: #FFFFFF;
  padding: 40rpx 32rpx;
  margin: 16rpx 32rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.stats-date {
  font-size: 24rpx;
  color: #999999;
  border: 1rpx solid #E5E7EB;
  padding: 8rpx 16rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111111;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.chart-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin: 0 32rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 32rpx;
  display: block;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
}