.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 0;
}

.profile-header {
  background-color: #FFFFFF;
  padding: 80rpx 32rpx 60rpx;
  text-align: center;
  border-bottom: 2rpx solid #e8ebf0;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto 32rpx;
  color: #0066FF;
  background: rgba(0,102,255,0.08);
  border-radius: 40rpx;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #191919;
  display: block;
  margin-bottom: 12rpx;
}

.profile-desc {
  font-size: 28rpx;
  color: #666666;
  display: block;
}

.profile-menu {
  background-color: #FFFFFF;
  margin: 24rpx 0;
  border-radius: 32rpx;
  overflow: hidden;
  margin: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  position: relative;
  background: #FFFFFF;
}

.menu-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 40rpx;
  right: 40rpx;
  height: 2rpx;
  background-color: #f0f1f5;
}

.menu-item:last-child::after {
  display: none;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 28rpx;
  background: rgba(0,102,255,0.05);
  border-radius: 16rpx;
  color: #0066FF;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #191919;
  font-weight: 500;
}

.menu-arrow {
  color: #999999;
  font-size: 28rpx;
}
