.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #191919;
}

.report-tabs {
  background-color: #FFFFFF;
  display: flex;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #e8ebf0;
}

.report-tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
  font-weight: 500;
}

.report-tab.active {
  color: #0066FF;
}

.report-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #0066FF;
  border-radius: 4rpx;
}

.report-content {
  padding: 32rpx;
}

.report-header {
  background-color: #FFFFFF;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
}

.date-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.date-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid #e8ebf0;
  border-radius: 16rpx;
  font-weight: 500;
}

.date-btn.active {
  background-color: #0066FF;
  color: #FFFFFF;
  border-color: #0066FF;
}

.report-summary {
  display: flex;
  justify-content: space-between;
}

.report-stat {
  display: flex;
  flex-direction: column;
  flex: 1;
  text-align: center;
}

.report-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 12rpx;
}

.report-stat-label {
  font-size: 24rpx;
  color: #999999;
}

.chart-card {
  background-color: #FFFFFF;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 32rpx;
  display: block;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, rgba(0,102,255,0.08) 0%, rgba(0,102,255,0.01) 100%);
  border-radius: 24rpx;
}

.report-list {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
}

.report-list-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 2rpx solid #f0f1f5;
}

.report-list-item:last-child {
  border-bottom: none;
}

.report-list-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 28rpx;
  border: 2rpx solid #e8ebf0;
  border-radius: 20rpx;
  color: #0066FF;
  background: rgba(0,102,255,0.05);
}

.report-list-info {
  flex: 1;
}

.report-list-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #191919;
  display: block;
  margin-bottom: 8rpx;
}

.report-list-meta {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.report-list-data {
  text-align: right;
}

.report-list-data-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #0066FF;
  display: block;
  margin-bottom: 4rpx;
}

.report-list-data-label {
  font-size: 22rpx;
  color: #999999;
  display: block;
}
