.container {
  padding-bottom: 120rpx;
}

.navbar {
  background-color: #FFFFFF;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #E5E7EB;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.report-tabs {
  background-color: #FFFFFF;
  display: flex;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.report-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
  font-weight: 500;
}

.report-tab.active {
  color: #0F62FE;
}

.report-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #0F62FE;
}

.report-content {
  padding: 32rpx;
}

.report-header {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.date-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.date-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
  border: 1rpx solid #E5E7EB;
  font-weight: 500;
}

.date-btn.active {
  background-color: #0F62FE;
  color: #FFFFFF;
  border-color: #0F62FE;
}

.report-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
}

.report-stat {
  display: flex;
  flex-direction: column;
}

.report-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 8rpx;
}

.report-stat-label {
  font-size: 24rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.chart-card {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 32rpx;
  display: block;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
}

.report-list {
  background-color: #FFFFFF;
}

.report-list-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.report-list-item:last-child {
  border-bottom: none;
}

.report-list-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
  border: 1rpx solid #E5E7EB;
  color: #0F62FE;
}

.report-list-info {
  flex: 1;
}

.report-list-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
  display: block;
  margin-bottom: 6rpx;
}

.report-list-meta {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.report-list-data {
  text-align: right;
}

.report-list-data-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
  display: block;
}

.report-list-data-label {
  font-size: 22rpx;
  color: #999999;
  display: block;
}